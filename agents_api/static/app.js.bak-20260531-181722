const { createApp, ref, computed, reactive, nextTick, onMounted } = Vue;
const { ElMessage } = ElementPlus;

const API_BASE = window.location.origin;
const ACTIVITY_STORAGE_KEY = 'hermes-dashboard-activity';

const app = createApp({
  setup() {
    const activeMenu = ref('dashboard');
    const pageMetaMap = {
      dashboard: {
        title: 'Nexus 控制台',
        desc: '总览多智能体系统运行态、平台指标与最近协作活动。'
      },
      agents: {
        title: '智能体矩阵',
        desc: '浏览角色、模型、状态与单智能体会话入口。'
      },
      cluster: {
        title: '集群对话作战台',
        desc: '提交任务、查看总指挥分析过程与各智能体执行结果。'
      },
      knowledge: {
        title: '知识库管理',
        desc: '检索、录入与审视知识资产，不修改后端即可完成数据运维。'
      },
      evolution: {
        title: '进化系统',
        desc: '跟踪平台学习次数、技能沉淀与最近的自动演化记录。'
      }
    };

    const platform = reactive({
      platform: 'Hermes 智能体管理平台',
      version: '3.0',
      status: 'running',
      agents_count: 0,
      knowledge_docs: 0
    });

    const systemStats = reactive({
      agents: 0,
      knowledge_docs: 0,
      cache_size: 0,
      cache_max: 0,
      evolution_count: 0,
      uptime: '运行中'
    });

    const agents = ref([]);
    const agentSearch = ref('');
    const showNewAgentDialog = ref(false);
    const newAgentForm = reactive({
      name: '',
      role: '',
      description: ''
    });

    const kbDocs = ref([]);
    const kbLoading = ref(false);
    const kbSearchQuery = ref('');
    const kbSearchResults = ref(null);
    const addKbVisible = ref(false);
    const kbAdding = ref(false);
    const addKbForm = reactive({ content: '', tagsStr: '', source: '' });

    const clusterInput = ref('');
    const clusterLoading = ref(false);
    const clusterMessages = ref([]);
    const clusterRounds = ref([]);
    const clusterKnowledge = ref([]);
    const clusterMsgs = ref(null);
    const sessionId = ref('session_' + Date.now());

    const agentChatVisible = ref(false);
    const chatAgent = ref(null);
    const agentChatInput = ref('');
    const agentChatLoading = ref(false);
    const agentChatHistory = ref([]);
    const agentChatMsgs = ref(null);

    const evolutionStats = reactive({
      total_learned: 0,
      skills_count: 0,
      knowledge_base_size: 0,
      recent_learnings: []
    });
    const evolutionSummary = ref('');

    const recentActivities = ref(loadSavedActivities());

    function loadSavedActivities() {
      try {
        return JSON.parse(localStorage.getItem(ACTIVITY_STORAGE_KEY) || '[]');
      } catch {
        return [];
      }
    }

    function saveActivities() {
      localStorage.setItem(ACTIVITY_STORAGE_KEY, JSON.stringify(recentActivities.value.slice(0, 12)));
    }

    function addActivity(type, title, detail = '') {
      const typeMap = {
        cluster: '集群协作',
        agent: '单智能体对话',
        knowledge: '知识库',
        system: '系统'
      };
      recentActivities.value.unshift({
        id: Date.now() + Math.random().toString(36).slice(2, 6),
        type,
        typeLabel: typeMap[type] || '活动',
        title,
        detail,
        time: new Date().toISOString()
      });
      recentActivities.value = recentActivities.value.slice(0, 12);
      saveActivities();
    }

    async function apiGet(path) {
      const res = await fetch(API_BASE + path, {
        signal: AbortSignal.timeout(30000)
      });
      if (!res.ok) {
        throw new Error(`GET ${path} 失败 (${res.status})`);
      }
      return res.json();
    }

    async function apiPost(path, body) {
      const res = await fetch(API_BASE + path, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
        signal: AbortSignal.timeout(120000)
      });
      if (!res.ok) {
        throw new Error(`POST ${path} 失败 (${res.status})`);
      }
      return res.json();
    }

    function formatContent(text) {
      if (!text) return '';
      let html = String(text)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\n/g, '<br>')
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      if (html.includes('【思考过程】') && html.includes('【回答】')) {
        const parts = html.split('【回答】');
        const thinkPart = parts[0].replace('【思考过程】', '').trim();
        const answerPart = '【回答】' + parts.slice(1).join('【回答】');
        html = `<div class="answer-block">${answerPart}</div>
          <details class="thinking-block">
            <summary>查看思考过程</summary>
            <div class="thinking-inner">${thinkPart}</div>
          </details>`;
      }
      return html;
    }

    function formatTime(value) {
      if (!value) return '--';
      return new Date(value).toLocaleTimeString('zh-CN', {
        hour: '2-digit',
        minute: '2-digit'
      });
    }

    function formatDateTime(value) {
      if (!value) return '--';
      return new Date(value).toLocaleString('zh-CN', {
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit'
      });
    }

    function scrollChat(type) {
      nextTick(() => {
        const el = type === 'agent' ? agentChatMsgs.value : clusterMsgs.value;
        if (el) el.scrollTop = el.scrollHeight;
      });
    }

    async function loadPlatform() {
      const [rootData, statsData] = await Promise.all([
        apiGet('/'),
        apiGet('/system/stats')
      ]);
      Object.assign(platform, rootData);
      Object.assign(systemStats, statsData);
    }

    async function loadAgents() {
      const data = await apiGet('/agents');
      agents.value = data.agents || [];
    }

    async function loadKnowledge() {
      kbLoading.value = true;
      try {
        const data = await apiGet('/knowledge');
        kbDocs.value = data.documents || [];
        if (!kbSearchQuery.value) {
          kbSearchResults.value = null;
        }
      } finally {
        kbLoading.value = false;
      }
    }

    async function loadEvolution() {
      const [statsData, summaryData] = await Promise.all([
        apiGet('/evolution'),
        apiGet('/evolution/summary')
      ]);
      Object.assign(evolutionStats, statsData);
      evolutionSummary.value = summaryData.summary || '暂无进化摘要';
    }

    async function loadDashboard() {
      await Promise.all([
        loadPlatform(),
        loadAgents(),
        loadKnowledge(),
        loadEvolution()
      ]);
    }

    async function handleMenuSelect(index) {
      activeMenu.value = index;
      if (index === 'dashboard') await loadDashboard();
      if (index === 'agents') await loadAgents();
      if (index === 'knowledge') await loadKnowledge();
      if (index === 'evolution') await loadEvolution();
    }

    async function refreshCurrentPage() {
      try {
        await handleMenuSelect(activeMenu.value);
        ElMessage.success('数据已刷新');
      } catch (error) {
        ElMessage.error(error.message || '刷新失败');
      }
    }

    function openAgentPanel(agent) {
      chatAgent.value = agent;
      agentChatHistory.value = [];
      agentChatInput.value = '';
      agentChatVisible.value = true;
    }

    async function sendAgentChat() {
      const msg = agentChatInput.value.trim();
      if (!msg || agentChatLoading.value || !chatAgent.value) return;
      agentChatHistory.value.push({ role: 'user', content: msg });
      agentChatInput.value = '';
      agentChatLoading.value = true;
      scrollChat('agent');
      try {
        const data = await apiPost(`/agents/${chatAgent.value.name}/chat`, { message: msg });
        agentChatHistory.value.push({ role: 'assistant', content: data.response || '无响应' });
        addActivity('agent', `${chatAgent.value.name} 完成一次会话`, msg.slice(0, 60));
      } catch (error) {
        agentChatHistory.value.push({ role: 'assistant', content: '请求失败: ' + error.message });
      } finally {
        agentChatLoading.value = false;
        scrollChat('agent');
      }
    }

    async function searchKnowledge() {
      const q = kbSearchQuery.value.trim();
      if (!q) {
        kbSearchResults.value = null;
        return;
      }
      try {
        const data = await apiPost('/knowledge/search', { query: q, top_k: 10 });
        kbSearchResults.value = data.results || [];
      } catch (error) {
        ElMessage.error(error.message || '搜索失败');
      }
    }

    function showAddKbDialog() {
      addKbForm.content = '';
      addKbForm.tagsStr = '';
      addKbForm.source = '';
      addKbVisible.value = true;
    }

    async function addKnowledge() {
      if (!addKbForm.content.trim()) return;
      kbAdding.value = true;
      try {
        const tags = addKbForm.tagsStr.split(',').map((tag) => tag.trim()).filter(Boolean);
        await apiPost('/knowledge/add', {
          content: addKbForm.content,
          tags,
          source: addKbForm.source
        });
        addKbVisible.value = false;
        addActivity('knowledge', '新增一条知识', addKbForm.content.slice(0, 60));
        await loadKnowledge();
        await loadPlatform();
        ElMessage.success('知识添加成功');
      } catch (error) {
        ElMessage.error(error.message || '添加失败');
      } finally {
        kbAdding.value = false;
      }
    }

    async function sendClusterTask() {
      const msg = clusterInput.value.trim();
      if (!msg || clusterLoading.value) return;
      clusterMessages.value.push({ role: 'user', content: msg, type: 'user' });
      clusterInput.value = '';
      clusterLoading.value = true;
      scrollChat('cluster');
      try {
        const data = await apiPost('/cluster/run', { task: msg, session_id: sessionId.value });
        clusterRounds.value = data.rounds || [];
        clusterKnowledge.value = data.knowledge_used || [];

        if (data.orchestration) {
          clusterMessages.value.push({
            role: 'assistant',
            content: data.orchestration,
            type: 'orchestration',
            meta: '总指挥分析'
          });
        }
        if (clusterKnowledge.value.length > 0) {
          clusterMessages.value.push({
            role: 'assistant',
            content: clusterKnowledge.value.map((item) => `· ${item}`).join('\n'),
            type: 'knowledge',
            meta: `命中 ${clusterKnowledge.value.length} 条知识`
          });
        }
        (data.results || []).forEach((result) => {
          clusterMessages.value.push({
            role: 'assistant',
            content: result.result,
            type: 'agent',
            agent: result.agent,
            meta: result.task || '执行结果'
          });
        });
        addActivity('cluster', '完成一次集群协作', msg.slice(0, 60));
        await loadEvolution();
        await loadPlatform();
      } catch (error) {
        clusterMessages.value.push({
          role: 'assistant',
          content: '请求超时或失败: ' + error.message,
          type: 'agent',
          agent: '系统',
          meta: '错误'
        });
      } finally {
        clusterLoading.value = false;
        scrollChat('cluster');
      }
    }

    async function copyGeneratedYaml() {
      try {
        await navigator.clipboard.writeText(generatedAgentYaml.value);
        ElMessage.success('YAML 已复制');
      } catch {
        ElMessage.warning('复制失败，请手动复制');
      }
    }

    const pageMeta = computed(() => pageMetaMap[activeMenu.value] || pageMetaMap.dashboard);
    const apiBaseLabel = computed(() => API_BASE.replace(/^https?:\/\//, ''));
    const filteredAgents = computed(() => {
      const keyword = agentSearch.value.trim().toLowerCase();
      if (!keyword) return agents.value;
      return agents.value.filter((agent) =>
        [agent.name, agent.role, agent.description]
          .filter(Boolean)
          .some((field) => field.toLowerCase().includes(keyword))
      );
    });

    const dashboardMetrics = computed(() => {
      const items = [
        {
          key: 'agents',
          label: '在线智能体',
          value: platform.agents_count || agents.value.length,
          icon: 'UserFilled',
          subtext: '当前可编排角色'
        },
        {
          key: 'knowledge',
          label: '知识库文档',
          value: systemStats.knowledge_docs || platform.knowledge_docs || kbDocs.value.length,
          icon: 'Collection',
          subtext: '可检索上下文片段'
        },
        {
          key: 'evolution',
          label: '进化学习次数',
          value: systemStats.evolution_count || evolutionStats.total_learned,
          icon: 'TrendCharts',
          subtext: '自动沉淀的经验'
        },
        {
          key: 'cache',
          label: '缓存命中池',
          value: systemStats.cache_size || 0,
          icon: 'DataAnalysis',
          subtext: `容量上限 ${systemStats.cache_max || 0}`
        }
      ];
      const max = Math.max(...items.map((item) => Number(item.value) || 0), 1);
      return items.map((item) => ({
        ...item,
        percent: Math.max(8, Math.round(((Number(item.value) || 0) / max) * 100))
      }));
    });

    const evolutionMetrics = computed(() => ([
      {
        key: 'learned',
        label: '累计学习次数',
        value: evolutionStats.total_learned,
        icon: 'TrendCharts',
        subtext: '自动学习总次数'
      },
      {
        key: 'skills',
        label: '技能沉淀',
        value: evolutionStats.skills_count,
        icon: 'MagicStick',
        subtext: '已生成技能文档'
      },
      {
        key: 'knowledgebase',
        label: '知识库总量',
        value: evolutionStats.knowledge_base_size,
        icon: 'Collection',
        subtext: '全局知识资产规模'
      }
    ]));

    const totalKbDocs = computed(() => kbDocs.value.length);
    const knowledgeSources = computed(() => {
      const sources = new Set();
      kbDocs.value.forEach((doc) => {
        if (doc.source) sources.add(doc.source);
      });
      return Array.from(sources);
    });

    const knowledgeTopTags = computed(() => {
      const countMap = {};
      kbDocs.value.forEach((doc) => {
        (doc.tags || []).forEach((tag) => {
          countMap[tag] = (countMap[tag] || 0) + 1;
        });
      });
      return Object.entries(countMap)
        .map(([name, count]) => ({ name, count }))
        .sort((a, b) => b.count - a.count)
        .slice(0, 12);
    });

    const generatedAgentYaml = computed(() => {
      const name = newAgentForm.name || 'NewAgent';
      const role = newAgentForm.role || '角色待定义';
      const description = newAgentForm.description || '补充这个智能体的职责和擅长方向';
      return [
        `name: "${name}"`,
        `role: "${role}"`,
        `description: "${description}"`,
        'model: "deepseek-v4-pro"',
        'provider: "deepseek"',
        'base_url: "https://api.deepseek.com"',
        'reasoning: true'
      ].join('\n');
    });

    const sessionIdShort = computed(() => sessionId.value.slice(-8));

    onMounted(async () => {
      try {
        await loadDashboard();
      } catch (error) {
        ElMessage.error(error.message || '初始化失败');
      }
    });

    return {
      activeMenu,
      pageMeta,
      platform,
      systemStats,
      agents,
      agentSearch,
      filteredAgents,
      showNewAgentDialog,
      newAgentForm,
      generatedAgentYaml,
      kbDocs,
      kbLoading,
      kbSearchQuery,
      kbSearchResults,
      addKbVisible,
      kbAdding,
      addKbForm,
      totalKbDocs,
      knowledgeSources,
      knowledgeTopTags,
      clusterInput,
      clusterLoading,
      clusterMessages,
      clusterRounds,
      clusterKnowledge,
      clusterMsgs,
      sessionIdShort,
      evolutionStats,
      evolutionSummary,
      dashboardMetrics,
      evolutionMetrics,
      recentActivities,
      apiBaseLabel,
      agentChatVisible,
      chatAgent,
      agentChatInput,
      agentChatLoading,
      agentChatHistory,
      agentChatMsgs,
      handleMenuSelect,
      refreshCurrentPage,
      openAgentPanel,
      sendAgentChat,
      showAddKbDialog,
      addKnowledge,
      searchKnowledge,
      sendClusterTask,
      copyGeneratedYaml,
      formatContent,
      formatTime,
      formatDateTime
    };
  }
});

for (const [key, component] of Object.entries(ElementPlusIconsVue)) {
  app.component(key, component);
}

app.use(ElementPlus);
app.mount('#app');
