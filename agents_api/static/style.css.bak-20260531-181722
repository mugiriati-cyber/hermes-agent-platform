/* Hermes 多智能体管理后台 · 深色科技感重构 */

:root {
  --bg-page: #060914;
  --bg-panel: rgba(13, 19, 39, 0.72);
  --bg-panel-strong: rgba(17, 24, 51, 0.82);
  --bg-panel-soft: rgba(16, 21, 42, 0.62);
  --bg-highlight: rgba(111, 76, 255, 0.12);
  --border-soft: rgba(155, 124, 255, 0.12);
  --border-strong: rgba(155, 124, 255, 0.26);
  --text-primary: #eef2ff;
  --text-secondary: #b7bfd8;
  --text-muted: #7f89a7;
  --purple: #8b5cf6;
  --purple-strong: #7c3aed;
  --blue: #38bdf8;
  --green: #22c55e;
  --orange: #f59e0b;
  --danger: #f87171;
  --radius-sm: 10px;
  --radius-md: 18px;
  --radius-lg: 28px;
  --shadow-lg: 0 24px 80px rgba(0, 0, 0, 0.4);
  --shadow-md: 0 12px 36px rgba(7, 13, 31, 0.35);
  --gradient-brand: linear-gradient(135deg, #7c3aed 0%, #8b5cf6 35%, #38bdf8 100%);
  --gradient-card: linear-gradient(180deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.01) 100%);
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  scrollbar-width: thin;
  scrollbar-color: rgba(139, 92, 246, 0.34) transparent;
}

html,
body {
  height: 100%;
  background: var(--bg-page);
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: var(--text-primary);
  overflow: hidden;
  position: relative;
}

body::before,
body::after {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

body::before {
  background:
    radial-gradient(circle at 12% 12%, rgba(124, 58, 237, 0.18), transparent 28%),
    radial-gradient(circle at 82% 18%, rgba(56, 189, 248, 0.12), transparent 26%),
    radial-gradient(circle at 65% 82%, rgba(139, 92, 246, 0.14), transparent 28%),
    linear-gradient(180deg, #050711 0%, #0a1022 100%);
}

body::after {
  background-image:
    radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,0.35), transparent),
    radial-gradient(1px 1px at 35% 12%, rgba(255,255,255,0.22), transparent),
    radial-gradient(1.4px 1.4px at 48% 25%, rgba(255,255,255,0.24), transparent),
    radial-gradient(1px 1px at 70% 15%, rgba(255,255,255,0.16), transparent),
    radial-gradient(1px 1px at 84% 32%, rgba(255,255,255,0.28), transparent),
    radial-gradient(1px 1px at 20% 78%, rgba(255,255,255,0.14), transparent),
    radial-gradient(1px 1px at 61% 72%, rgba(255,255,255,0.18), transparent),
    radial-gradient(1px 1px at 88% 80%, rgba(255,255,255,0.18), transparent);
  opacity: 0.6;
}

#app {
  position: relative;
  z-index: 1;
}

.app-shell {
  height: 100vh;
}

.app-aside {
  padding: 24px 18px;
  background: rgba(9, 14, 31, 0.72) !important;
  border-right: 1px solid var(--border-soft);
  backdrop-filter: blur(24px) saturate(160%);
  -webkit-backdrop-filter: blur(24px) saturate(160%);
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.aside-top {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 8px 10px 18px;
}

.brand-mark {
  width: 44px;
  height: 44px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gradient-brand);
  color: #fff;
  box-shadow: 0 18px 36px rgba(124, 58, 237, 0.28);
}

.brand-title {
  font-size: 19px;
  font-weight: 700;
}

.brand-subtitle {
  font-size: 12px;
  color: var(--text-muted);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-top: 4px;
}

.side-menu {
  flex: 1;
  background: transparent !important;
  border-right: none !important;
}

.side-menu .el-menu-item {
  height: 48px;
  line-height: 48px;
  margin: 4px 0;
  border-radius: 14px;
  color: var(--text-secondary) !important;
  transition: all 0.25s ease;
}

.side-menu .el-menu-item:hover {
  background: rgba(139, 92, 246, 0.08) !important;
  color: var(--text-primary) !important;
}

.side-menu .el-menu-item.is-active {
  background: rgba(124, 58, 237, 0.16) !important;
  color: #fff !important;
  box-shadow: inset 0 0 0 1px rgba(139, 92, 246, 0.22);
}

.sidebar-panels {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.sidebar-panel {
  padding: 16px;
  background: var(--bg-panel-soft);
  border: 1px solid var(--border-soft);
  border-radius: 16px;
}

.sidebar-panel-label,
.card-meta,
.metric-label,
.status-label,
.mini-stat-label,
.chip-label {
  font-size: 12px;
  color: var(--text-muted);
}

.sidebar-status {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 10px 0 6px;
  font-size: 14px;
}

.status-dot {
  width: 9px;
  height: 9px;
  border-radius: 999px;
  background: var(--green);
  box-shadow: 0 0 16px rgba(34, 197, 94, 0.65);
  flex-shrink: 0;
}

.sidebar-panel-meta {
  font-size: 12px;
  color: var(--text-secondary);
  word-break: break-all;
}

.sidebar-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.main-shell {
  background: transparent;
}

.app-header {
  height: auto;
  padding: 28px 32px 8px;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20px;
}

.header-eyebrow {
  color: var(--blue);
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 8px;
}

.header-title {
  font-size: 34px;
  line-height: 1.1;
  margin-bottom: 10px;
}

.header-desc {
  color: var(--text-secondary);
  max-width: 680px;
  line-height: 1.7;
  font-size: 14px;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.status-chip,
.metric-chip {
  padding: 12px 14px;
  background: var(--bg-panel-soft);
  border: 1px solid var(--border-soft);
  border-radius: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--text-secondary);
}

.metric-chip {
  min-width: 124px;
  justify-content: space-between;
}

.app-main {
  padding: 12px 32px 32px;
  overflow-y: auto;
}

.page {
  display: flex;
  flex-direction: column;
  gap: 24px;
  animation: fadeInUp 0.35s ease;
}

.page-title {
  font-size: 26px;
  margin-bottom: 6px;
}

.page-desc {
  color: var(--text-secondary);
  font-size: 14px;
  line-height: 1.7;
}

.section-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20px;
}

.toolbar-actions,
.toolbar-chip-list,
.hero-actions,
.cluster-input-actions {
  display: flex;
  gap: 10px;
  align-items: center;
}

.toolbar-search {
  width: 280px;
}

.glass-card {
  background: var(--bg-panel) !important;
  border: 1px solid var(--border-soft) !important;
  border-radius: var(--radius-md) !important;
  backdrop-filter: blur(22px) saturate(160%);
  -webkit-backdrop-filter: blur(22px) saturate(160%);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

.glass-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--gradient-card);
  pointer-events: none;
}

.glass-card .el-card__body,
.glass-card .el-card__header {
  position: relative;
  z-index: 1;
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18px;
  gap: 12px;
}

.hero-grid,
.dashboard-grid,
.knowledge-layout,
.cluster-layout,
.evolution-layout {
  display: grid;
  gap: 20px;
}

.hero-grid {
  grid-template-columns: minmax(0, 2fr) minmax(320px, 1fr);
}

.hero-card .el-card__body {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 20px;
  align-items: center;
}

.hero-kicker {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--blue);
  margin-bottom: 12px;
}

.hero-copy h2 {
  font-size: 32px;
  line-height: 1.2;
  margin-bottom: 14px;
}

.hero-copy p {
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 22px;
}

.hero-orbit {
  width: 240px;
  height: 240px;
  margin: 0 auto;
  border-radius: 50%;
  border: 1px solid rgba(139, 92, 246, 0.22);
  position: relative;
  box-shadow: inset 0 0 48px rgba(124, 58, 237, 0.12);
}

.hero-orbit::before,
.hero-orbit::after {
  content: '';
  position: absolute;
  inset: 24px;
  border: 1px dashed rgba(56, 189, 248, 0.18);
  border-radius: 50%;
}

.hero-orbit::after {
  inset: 54px;
  border-color: rgba(139, 92, 246, 0.22);
}

.orbit-center,
.orbit-node {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: var(--bg-panel-strong);
  border: 1px solid var(--border-strong);
}

.orbit-center {
  inset: 82px;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: #fff;
}

.orbit-node {
  width: 54px;
  height: 54px;
  color: var(--text-secondary);
}

.orbit-node-1 {
  top: 12px;
  left: 92px;
}

.orbit-node-2 {
  right: 16px;
  top: 110px;
}

.orbit-node-3 {
  left: 26px;
  bottom: 22px;
}

.hero-side,
.knowledge-side,
.cluster-side {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.status-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.status-item {
  padding: 14px;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.04);
}

.status-item strong,
.mini-stat-value,
.metric-value {
  display: block;
  margin-top: 8px;
  font-size: 24px;
  color: #fff;
}

.mini-activity-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.mini-activity-item {
  padding: 12px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.mini-activity-item:last-child {
  border-bottom: none;
}

.mini-activity-type {
  font-size: 11px;
  color: var(--blue);
  margin-bottom: 6px;
}

.mini-activity-content {
  font-size: 14px;
  margin-bottom: 4px;
}

.mini-activity-time {
  color: var(--text-muted);
  font-size: 12px;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
}

.metric-card .el-card__body {
  display: flex;
  align-items: center;
  gap: 16px;
}

.metric-icon {
  width: 54px;
  height: 54px;
  border-radius: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22px;
}

.metric-agents,
.metric-learned {
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.88), rgba(139, 92, 246, 0.58));
}

.metric-knowledge,
.metric-knowledgebase {
  background: linear-gradient(135deg, rgba(56, 189, 248, 0.86), rgba(59, 130, 246, 0.54));
}

.metric-evolution,
.metric-skills {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.84), rgba(16, 185, 129, 0.52));
}

.metric-cache {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.84), rgba(249, 115, 22, 0.52));
}

.metric-subtext,
.knowledge-source,
.round-meta,
.cluster-hint {
  color: var(--text-muted);
  font-size: 12px;
  margin-top: 6px;
}

.dashboard-grid {
  grid-template-columns: minmax(0, 1.3fr) minmax(320px, 0.9fr);
}

.metric-bars {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.metric-bar-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
  color: var(--text-secondary);
}

.metric-bar-track {
  width: 100%;
  height: 12px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.05);
  overflow: hidden;
}

.metric-bar-fill {
  height: 100%;
  border-radius: inherit;
  background: var(--gradient-brand);
  box-shadow: 0 0 18px rgba(124, 58, 237, 0.35);
}

.capability-list {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.capability-item {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  padding: 14px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.03);
}

.capability-badge {
  min-width: 58px;
  height: 30px;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
}

.badge-purple {
  background: rgba(124, 58, 237, 0.18);
  color: #d8c9ff;
}

.badge-blue {
  background: rgba(56, 189, 248, 0.18);
  color: #b8edff;
}

.badge-green {
  background: rgba(34, 197, 94, 0.18);
  color: #bafad1;
}

.capability-title {
  font-weight: 600;
  margin-bottom: 6px;
}

.capability-desc {
  color: var(--text-secondary);
  line-height: 1.7;
  font-size: 13px;
}

.agents-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 18px;
}

.agent-card {
  cursor: pointer;
  transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
}

.agent-card:hover {
  transform: translateY(-4px);
  border-color: var(--border-strong) !important;
  box-shadow: 0 20px 48px rgba(20, 30, 68, 0.45);
}

.agent-card-top,
.knowledge-item-header,
.knowledge-item-footer,
.cluster-badge-row,
.round-item,
.card-title-row,
.agent-footer,
.agent-dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
}

.agent-name {
  font-size: 18px;
  font-weight: 700;
}

.agent-role {
  color: var(--text-secondary);
  font-size: 13px;
  margin-top: 6px;
}

.agent-status {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--text-secondary);
  font-size: 13px;
}

.agent-desc {
  margin: 16px 0;
  line-height: 1.8;
  color: var(--text-secondary);
  min-height: 66px;
}

.agent-tags,
.knowledge-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.agent-footer {
  margin-top: 18px;
  padding-top: 14px;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  color: var(--text-muted);
  font-size: 12px;
}

.cluster-layout {
  grid-template-columns: minmax(0, 1.55fr) minmax(300px, 0.8fr);
}

.cluster-chat-card .el-card__body {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.cluster-messages,
.chat-messages {
  min-height: 460px;
  max-height: 60vh;
  overflow-y: auto;
  padding-right: 6px;
}

.chat-msg,
.cluster-msg {
  margin-bottom: 16px;
}

.cluster-msg.user,
.chat-msg.user {
  display: flex;
  justify-content: flex-end;
}

.cluster-bubble,
.chat-bubble {
  max-width: 84%;
  padding: 14px 16px;
  border-radius: 18px;
  line-height: 1.75;
  font-size: 14px;
  word-break: break-word;
}

.user-bubble,
.chat-msg.user .chat-bubble {
  background: var(--gradient-brand);
  color: #fff;
  border-bottom-right-radius: 8px;
}

.assistant-bubble,
.chat-msg.assistant .chat-bubble {
  background: var(--bg-panel-strong);
  border: 1px solid var(--border-soft);
  border-bottom-left-radius: 8px;
}

.cluster-content {
  margin-top: 10px;
}

.cluster-badge-meta {
  color: var(--text-muted);
  font-size: 12px;
}

.cluster-input-panel {
  padding-top: 6px;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.cluster-input-actions {
  margin-top: 12px;
  justify-content: space-between;
}

.knowledge-layout,
.evolution-layout {
  grid-template-columns: minmax(0, 1.5fr) minmax(320px, 0.85fr);
}

.knowledge-overview {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
}

.mini-stat-card .el-card__body {
  padding: 20px 22px;
}

.knowledge-list {
  display: flex;
  flex-direction: column;
  gap: 14px;
  max-height: 70vh;
  overflow-y: auto;
}

.knowledge-item,
.timeline-card,
.round-item,
.knowledge-hit-item {
  padding: 16px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.04);
}

.knowledge-id {
  font-size: 12px;
  color: var(--blue);
}

.knowledge-time {
  color: var(--text-muted);
  font-size: 12px;
}

.knowledge-content,
.timeline-knowledge {
  margin: 12px 0 14px;
  line-height: 1.8;
  color: var(--text-secondary);
}

.timeline-title {
  font-weight: 700;
  margin-bottom: 8px;
}

.timeline-desc,
.timeline-skill {
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 10px;
}

.round-list,
.knowledge-hit-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.round-title {
  font-weight: 600;
}

.evolution-summary,
.yaml-preview {
  white-space: pre-wrap;
  line-height: 1.8;
  color: var(--text-secondary);
  font-family: inherit;
}

.yaml-preview {
  margin-top: 12px;
  padding: 16px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--border-soft);
  font-family: 'SFMono-Regular', Consolas, monospace;
  font-size: 13px;
}

.new-agent-note {
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 18px;
}

.panel-loading {
  padding: 12px 0;
}

.ghost-button {
  background: rgba(255, 255, 255, 0.04) !important;
  border-color: rgba(255, 255, 255, 0.08) !important;
  color: var(--text-primary) !important;
}

.thinking-block {
  margin-top: 10px;
}

.thinking-block summary {
  color: var(--blue);
  cursor: pointer;
  font-size: 13px;
}

.thinking-inner {
  margin-top: 10px;
  padding: 12px 14px;
  border-radius: 12px;
  background: rgba(56, 189, 248, 0.08);
  color: #c7efff;
}

.answer-block {
  color: var(--text-primary);
}

.el-card,
.el-dialog,
.el-popper {
  background: var(--bg-panel) !important;
  border-color: var(--border-soft) !important;
  color: var(--text-primary) !important;
}

.el-card {
  box-shadow: var(--shadow-md) !important;
}

.el-card__header {
  border-bottom-color: rgba(255, 255, 255, 0.06) !important;
}

.el-menu {
  background: transparent !important;
}

.el-button--primary {
  --el-button-bg-color: #7c3aed;
  --el-button-border-color: #7c3aed;
  --el-button-hover-bg-color: #6d28d9;
  --el-button-hover-border-color: #6d28d9;
  --el-button-active-bg-color: #5b21b6;
  box-shadow: 0 10px 26px rgba(124, 58, 237, 0.28);
}

.el-button--default {
  --el-button-bg-color: rgba(255, 255, 255, 0.04);
  --el-button-border-color: rgba(255, 255, 255, 0.08);
  --el-button-hover-bg-color: rgba(255, 255, 255, 0.08);
  --el-button-hover-border-color: rgba(155, 124, 255, 0.26);
  color: var(--text-primary);
}

.el-input__wrapper,
.el-textarea__inner,
.el-input-group__append,
.el-input-group__prepend {
  background: rgba(255, 255, 255, 0.04) !important;
  border-color: rgba(255, 255, 255, 0.08) !important;
  box-shadow: none !important;
}

.el-input__inner,
.el-textarea__inner {
  color: var(--text-primary) !important;
}

.el-input__inner::placeholder,
.el-textarea__inner::placeholder {
  color: var(--text-muted) !important;
}

.el-dialog {
  border-radius: 24px !important;
  backdrop-filter: blur(26px) saturate(160%);
  -webkit-backdrop-filter: blur(26px) saturate(160%);
}

.el-dialog__header,
.el-dialog__footer {
  border-color: rgba(255, 255, 255, 0.05) !important;
}

.el-dialog__title,
.el-form-item__label,
.el-timeline-item__timestamp,
.el-empty__description {
  color: var(--text-secondary) !important;
}

.el-tag {
  border: none !important;
  border-radius: 999px !important;
}

.el-overlay {
  background: rgba(4, 8, 18, 0.7) !important;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.el-timeline-item__node {
  background: var(--purple) !important;
  box-shadow: 0 0 18px rgba(139, 92, 246, 0.4);
}

.el-timeline-item__tail {
  border-left-color: rgba(155, 124, 255, 0.2) !important;
}

.el-empty {
  --el-empty-fill-color-0: rgba(124, 58, 237, 0.12);
}

::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(139, 92, 246, 0.28);
  border-radius: 999px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(139, 92, 246, 0.42);
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

::selection {
  background: rgba(124, 58, 237, 0.35);
  color: #fff;
}

:focus-visible {
  outline: 2px solid rgba(56, 189, 248, 0.65);
  outline-offset: 2px;
}

@media (max-width: 1360px) {
  .hero-grid,
  .dashboard-grid,
  .cluster-layout,
  .knowledge-layout,
  .evolution-layout {
    grid-template-columns: 1fr;
  }

  .stats-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 1100px) {
  .app-aside {
    width: 220px !important;
  }

  .hero-card .el-card__body {
    grid-template-columns: 1fr;
  }

  .app-header,
  .section-toolbar {
    flex-direction: column;
    align-items: flex-start;
  }

  .header-actions,
  .toolbar-actions {
    width: 100%;
    flex-wrap: wrap;
  }

  .toolbar-search {
    width: 100%;
  }
}

@media (max-width: 768px) {
  .app-shell {
    flex-direction: column;
  }

  .app-aside {
    display: none;
  }

  .app-header,
  .app-main {
    padding-left: 18px;
    padding-right: 18px;
  }

  .header-title {
    font-size: 28px;
  }

  .stats-grid,
  .knowledge-overview {
    grid-template-columns: 1fr;
  }

  .cluster-bubble,
  .chat-bubble {
    max-width: 100%;
  }

  .cluster-input-actions {
    flex-direction: column;
    align-items: stretch;
  }
}
