<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hermes 智能体管理平台 v3.0</title>
<link rel="stylesheet" href="https://unpkg.com/element-plus/dist/index.css">
<link rel="stylesheet" href="/static/style.css">
</head>
<body>
<div id="app">
  <el-container class="app-shell">
    <el-aside width="248px" class="app-aside">
      <div class="aside-top">
        <div class="brand-mark">
          <el-icon :size="22"><Monitor /></el-icon>
        </div>
        <div class="brand-copy">
          <div class="brand-title">Hermes Nexus</div>
          <div class="brand-subtitle">Multi-Agent Control</div>
        </div>
      </div>

      <el-menu
        :default-active="activeMenu"
        @select="handleMenuSelect"
        class="side-menu"
      >
        <el-menu-item index="dashboard">
          <el-icon><Odometer /></el-icon>
          <span>控制台</span>
        </el-menu-item>
        <el-menu-item index="agents">
          <el-icon><UserFilled /></el-icon>
          <span>智能体</span>
        </el-menu-item>
        <el-menu-item index="cluster">
          <el-icon><Connection /></el-icon>
          <span>集群对话</span>
        </el-menu-item>
        <el-menu-item index="knowledge">
          <el-icon><Collection /></el-icon>
          <span>知识库</span>
        </el-menu-item>
        <el-menu-item index="evolution">
          <el-icon><TrendCharts /></el-icon>
          <span>进化系统</span>
        </el-menu-item>
      </el-menu>

      <div class="sidebar-panels">
        <div class="sidebar-panel">
          <div class="sidebar-panel-label">运行状态</div>
          <div class="sidebar-status">
            <span class="status-dot"></span>
            <span>{{ platform.status || 'unknown' }}</span>
          </div>
          <div class="sidebar-panel-meta">API Root · {{ apiBaseLabel }}</div>
        </div>
        <div class="sidebar-tags">
          <el-tag size="small" effect="dark">v3.0</el-tag>
          <el-tag size="small" effect="dark" type="success">RAG</el-tag>
          <el-tag size="small" effect="dark" color="#7c3aed">deepseek-v4-pro</el-tag>
        </div>
      </div>
    </el-aside>

    <el-container class="main-shell">
      <el-header class="app-header">
        <div>
          <div class="header-eyebrow">多智能体管理后台</div>
          <h1 class="header-title">{{ pageMeta.title }}</h1>
          <p class="header-desc">{{ pageMeta.desc }}</p>
        </div>
        <div class="header-actions">
          <div class="status-chip">
            <span class="status-dot"></span>
            <span>{{ platform.platform || 'Hermes 平台' }}</span>
          </div>
          <el-button class="ghost-button" @click="refreshCurrentPage" :icon="RefreshRight">刷新数据</el-button>
        </div>
      </el-header>

      <el-main class="app-main">
        <section v-show="activeMenu === 'dashboard'" class="page page-dashboard">
          <div class="hero-grid">
            <el-card class="hero-card glass-card">
              <div class="hero-copy">
                <div class="hero-kicker">Hermes Orchestrator</div>
                <h2>让多智能体协作、知识检索与自进化运行在同一控制台。</h2>
                <p>
                  当前前端直接连接现有 FastAPI 接口，聚合平台运行状态、集群协作记录、
                  知识库规模与进化学习数据，不修改任何后端逻辑。
                </p>
                <div class="hero-actions">
                  <el-button type="primary" @click="activeMenu = 'cluster'; handleMenuSelect('cluster')">
                    开始集群对话
                  </el-button>
                  <el-button class="ghost-button" @click="activeMenu = 'agents'; handleMenuSelect('agents')">
                    查看智能体
                  </el-button>
                </div>
              </div>
              <div class="hero-orbit">
                <div class="orbit-center">NEXUS</div>
                <div class="orbit-node orbit-node-1">AI</div>
                <div class="orbit-node orbit-node-2">RAG</div>
                <div class="orbit-node orbit-node-3">EVO</div>
              </div>
            </el-card>

            <div class="hero-side">
              <el-card class="glass-card status-card">
                <div class="card-title-row">
                  <span>系统状态</span>
                  <el-tag type="success" effect="dark">在线</el-tag>
                </div>
                <div class="status-grid">
                  <div class="status-item">
                    <span class="status-label">平台版本</span>
                    <strong>{{ platform.version || '3.0' }}</strong>
                  </div>
                  <div class="status-item">
                    <span class="status-label">默认模型</span>
                    <strong>deepseek-v4-pro</strong>
                  </div>
                  <div class="status-item">
                    <span class="status-label">缓存状态</span>
                    <strong>{{ systemStats.cache_size }} / {{ systemStats.cache_max }}</strong>
                  </div>
                  <div class="status-item">
                    <span class="status-label">运行态</span>
                    <strong>{{ systemStats.uptime || platform.status || '运行中' }}</strong>
                  </div>
                </div>
              </el-card>

              <el-card class="glass-card mini-activity-card">
                <div class="card-title-row">
                  <span>最近活动</span>
                  <span class="card-meta">{{ recentActivities.length }} 条</span>
                </div>
                <div v-if="recentActivities.length" class="mini-activity-list">
                  <div v-for="item in recentActivities.slice(0, 4)" :key="item.id" class="mini-activity-item">
                    <div class="mini-activity-type">{{ item.typeLabel }}</div>
                    <div class="mini-activity-content">{{ item.title }}</div>
                    <div class="mini-activity-time">{{ formatTime(item.time) }}</div>
                  </div>
                </div>
                <el-empty v-else description="还没有最近活动记录" />
              </el-card>
            </div>
          </div>

          <div class="stats-grid">
            <el-card v-for="metric in dashboardMetrics" :key="metric.key" class="metric-card glass-card">
              <div class="metric-icon" :class="'metric-' + metric.key">
                <el-icon><component :is="metric.icon" /></el-icon>
              </div>
              <div class="metric-body">
                <div class="metric-label">{{ metric.label }}</div>
                <div class="metric-value">{{ metric.value }}</div>
                <div class="metric-subtext">{{ metric.subtext }}</div>
              </div>
            </el-card>
          </div>

          <div class="dashboard-grid">
            <el-card class="glass-card chart-card">
              <div class="card-title-row">
                <span>平台指标分布</span>
                <span class="card-meta">实时采样</span>
              </div>
              <div class="metric-bars">
                <div v-for="metric in dashboardMetrics" :key="metric.key" class="metric-bar-row">
                  <div class="metric-bar-head">
                    <span>{{ metric.label }}</span>
                    <strong>{{ metric.value }}</strong>
                  </div>
                  <div class="metric-bar-track">
                    <div class="metric-bar-fill" :style="{ width: metric.percent + '%' }"></div>
                  </div>
                </div>
              </div>
            </el-card>

            <el-card class="glass-card insight-card">
              <div class="card-title-row">
                <span>核心能力</span>
                <span class="card-meta">平台矩阵</span>
              </div>
              <div class="capability-list">
                <div class="capability-item">
                  <div class="capability-badge badge-purple">ORCH</div>
                  <div>
                    <div class="capability-title">Orchestrator 编排</div>
                    <div class="capability-desc">多轮计划、反馈调度与协作执行</div>
                  </div>
                </div>
                <div class="capability-item">
                  <div class="capability-badge badge-blue">RAG</div>
                  <div>
                    <div class="capability-title">知识检索增强</div>
                    <div class="capability-desc">知识库检索结果直接注入智能体上下文</div>
                  </div>
                </div>
                <div class="capability-item">
                  <div class="capability-badge badge-green">EVO</div>
                  <div>
                    <div class="capability-title">自进化学习</div>
                    <div class="capability-desc">自动沉淀知识点与技能模式</div>
                  </div>
                </div>
              </div>
            </el-card>
          </div>
        </section>

        <section v-show="activeMenu === 'agents'" class="page">
          <div class="section-toolbar">
            <div class="toolbar-copy">
              <h2 class="page-title">智能体矩阵</h2>
              <p class="page-desc">查看全部角色、模型与当前可用能力，支持直接发起单智能体对话。</p>
            </div>
            <div class="toolbar-actions">
              <el-input
                v-model="agentSearch"
                placeholder="搜索智能体名称 / 角色"
                clearable
                class="toolbar-search"
              >
                <template #prefix><el-icon><Search /></el-icon></template>
              </el-input>
              <el-button type="primary" @click="showNewAgentDialog = true">新增智能体</el-button>
            </div>
          </div>

          <div class="agents-grid">
            <el-card
              v-for="agent in filteredAgents"
              :key="agent.name"
              class="agent-card glass-card"
              @click="openAgentPanel(agent)"
            >
              <div class="agent-card-top">
                <div>
                  <div class="agent-name">{{ agent.name }}</div>
                  <div class="agent-role">{{ agent.role }}</div>
                </div>
                <div class="agent-status">
                  <span class="status-dot"></span>
                  <span>在线</span>
                </div>
              </div>
              <p class="agent-desc">{{ agent.description || '暂无描述' }}</p>
              <div class="agent-tags">
                <el-tag size="small" effect="dark">{{ agent.model || 'deepseek-v4-pro' }}</el-tag>
                <el-tag v-if="agent.reasoning" size="small" effect="dark" color="#7c3aed">思考模式</el-tag>
              </div>
              <div class="agent-footer">
                <span>点击查看详情与对话历史</span>
                <el-icon><ArrowRight /></el-icon>
              </div>
            </el-card>
          </div>

          <el-empty v-if="!filteredAgents.length" description="没有匹配的智能体"></el-empty>
        </section>

        <section v-show="activeMenu === 'cluster'" class="page">
          <div class="section-toolbar">
            <div class="toolbar-copy">
              <h2 class="page-title">集群对话作战台</h2>
              <p class="page-desc">输入任务后由 Orchestrator 分析、检索知识库，并显示各智能体执行结果。</p>
            </div>
            <div class="toolbar-chip-list">
              <div class="metric-chip">
                <span class="chip-label">会话 ID</span>
                <strong>{{ sessionIdShort }}</strong>
              </div>
              <div class="metric-chip">
                <span class="chip-label">轮次</span>
                <strong>{{ clusterRounds.length }}</strong>
              </div>
            </div>
          </div>

          <div class="cluster-layout">
            <el-card class="glass-card cluster-chat-card">
              <div class="cluster-messages" ref="clusterMsgs">
                <div v-if="clusterMessages.length === 0" class="empty-chat">
                  <el-empty description="输入任务后，智能体集群会在这里展开协作"></el-empty>
                </div>
                <div v-for="(m, i) in clusterMessages" :key="i" class="cluster-msg" :class="m.role">
                  <template v-if="m.role === 'user'">
                    <div class="cluster-bubble user-bubble">{{ m.content }}</div>
                  </template>
                  <template v-else>
                    <div class="cluster-bubble assistant-bubble">
                      <div class="cluster-badge-row">
                        <el-tag v-if="m.type === 'orchestration'" effect="dark" type="warning">总指挥</el-tag>
                        <el-tag v-else-if="m.type === 'knowledge'" effect="dark" type="info">知识检索</el-tag>
                        <el-tag v-else effect="dark" color="#7c3aed">{{ m.agent || '智能体' }}</el-tag>
                        <span class="cluster-badge-meta">{{ m.meta || '结果输出' }}</span>
                      </div>
                      <div class="cluster-content" v-html="formatContent(m.content)"></div>
                    </div>
                  </template>
                </div>
                <div v-if="clusterLoading" class="cluster-msg assistant">
                  <div class="cluster-bubble assistant-bubble typing">智能体集群正在编排与执行…</div>
                </div>
              </div>

              <div class="cluster-input-panel">
                <el-input
                  v-model="clusterInput"
                  type="textarea"
                  :rows="3"
                  placeholder="例如：帮我设计一个背包系统，并拆给合适的智能体执行"
                  @keydown.enter.exact.prevent="sendClusterTask"
                  :disabled="clusterLoading"
                />
                <div class="cluster-input-actions">
                  <div class="cluster-hint">Enter 发送，Shift + Enter 换行</div>
                  <el-button type="primary" size="large" @click="sendClusterTask" :disabled="clusterLoading" :loading="clusterLoading">
                    发起任务
                  </el-button>
                </div>
              </div>
            </el-card>

            <div class="cluster-side">
              <el-card class="glass-card side-card">
                <div class="card-title-row">
                  <span>协作轮次</span>
                  <span class="card-meta">{{ clusterRounds.length }} 轮</span>
                </div>
                <div v-if="clusterRounds.length" class="round-list">
                  <div v-for="round in clusterRounds" :key="round.round" class="round-item">
                    <div class="round-title">Round {{ round.round }}</div>
                    <div class="round-meta">{{ round.results.length }} 个结果</div>
                  </div>
                </div>
                <el-empty v-else description="等待首次任务"></el-empty>
              </el-card>

              <el-card class="glass-card side-card">
                <div class="card-title-row">
                  <span>知识命中</span>
                  <span class="card-meta">{{ clusterKnowledge.length }} 条</span>
                </div>
                <div v-if="clusterKnowledge.length" class="knowledge-hit-list">
                  <div v-for="(item, index) in clusterKnowledge" :key="index" class="knowledge-hit-item">
                    {{ item }}
                  </div>
                </div>
                <el-empty v-else description="暂无知识检索结果"></el-empty>
              </el-card>
            </div>
          </div>
        </section>

        <section v-show="activeMenu === 'knowledge'" class="page">
          <div class="section-toolbar">
            <div class="toolbar-copy">
              <h2 class="page-title">知识库管理</h2>
              <p class="page-desc">查看当前文档池、检索结果与知识录入情况，支持手动新增知识条目。</p>
            </div>
            <div class="toolbar-actions">
              <el-input
                v-model="kbSearchQuery"
                placeholder="搜索知识库..."
                clearable
                @keyup.enter="searchKnowledge"
                class="toolbar-search"
              >
                <template #prefix><el-icon><Search /></el-icon></template>
              </el-input>
              <el-button type="primary" @click="searchKnowledge">搜索</el-button>
              <el-button class="ghost-button" @click="showAddKbDialog">添加知识</el-button>
            </div>
          </div>

          <div class="knowledge-overview">
            <el-card class="glass-card mini-stat-card">
              <div class="mini-stat-label">文档总量</div>
              <div class="mini-stat-value">{{ totalKbDocs }}</div>
            </el-card>
            <el-card class="glass-card mini-stat-card">
              <div class="mini-stat-label">来源种类</div>
              <div class="mini-stat-value">{{ knowledgeSources.length }}</div>
            </el-card>
            <el-card class="glass-card mini-stat-card">
              <div class="mini-stat-label">热门标签</div>
              <div class="mini-stat-value">{{ knowledgeTopTags.length }}</div>
            </el-card>
          </div>

          <div class="knowledge-layout">
            <el-card class="glass-card knowledge-card">
              <div class="card-title-row">
                <span>知识条目</span>
                <span class="card-meta">共 {{ kbDocs.length }} 条</span>
              </div>

              <div v-if="kbLoading" class="panel-loading">
                <el-skeleton :rows="4" animated />
              </div>
              <div v-else class="knowledge-list">
                <div v-for="doc in kbDocs" :key="doc.id" class="knowledge-item">
                  <div class="knowledge-item-header">
                    <span class="knowledge-id">{{ doc.id }}</span>
                    <span class="knowledge-time">{{ formatDateTime(doc.added_at) }}</span>
                  </div>
                  <div class="knowledge-content">{{ doc.content }}</div>
                  <div class="knowledge-item-footer">
                    <div class="knowledge-tags">
                      <el-tag v-for="tag in (doc.tags || [])" :key="tag" size="small" effect="dark">{{ tag }}</el-tag>
                    </div>
                    <span class="knowledge-source">{{ doc.source || 'manual' }}</span>
                  </div>
                </div>
              </div>
            </el-card>

            <div class="knowledge-side">
              <el-card class="glass-card side-card">
                <div class="card-title-row">
                  <span>检索结果</span>
                  <span class="card-meta">{{ kbSearchResults ? kbSearchResults.length : 0 }} 条</span>
                </div>
                <div v-if="kbSearchResults && kbSearchResults.length" class="knowledge-hit-list">
                  <div v-for="(result, index) in kbSearchResults" :key="index" class="knowledge-hit-item">
                    {{ result }}
                  </div>
                </div>
                <el-empty v-else description="输入关键词后展示检索结果"></el-empty>
              </el-card>

              <el-card class="glass-card side-card">
                <div class="card-title-row">
                  <span>标签云</span>
                  <span class="card-meta">Top {{ knowledgeTopTags.length }}</span>
                </div>
                <div class="knowledge-tags cloud">
                  <el-tag
                    v-for="tag in knowledgeTopTags"
                    :key="tag.name"
                    size="small"
                    effect="dark"
                  >
                    {{ tag.name }} · {{ tag.count }}
                  </el-tag>
                </div>
              </el-card>
            </div>
          </div>
        </section>

        <section v-show="activeMenu === 'evolution'" class="page">
          <div class="section-toolbar">
            <div class="toolbar-copy">
              <h2 class="page-title">智能进化系统</h2>
              <p class="page-desc">观察学习次数、技能沉淀与最近演化记录，快速了解平台的自增能力。</p>
            </div>
          </div>

          <div class="stats-grid evolution-stats-grid">
            <el-card v-for="metric in evolutionMetrics" :key="metric.key" class="metric-card glass-card">
              <div class="metric-icon" :class="'metric-' + metric.key">
                <el-icon><component :is="metric.icon" /></el-icon>
              </div>
              <div class="metric-body">
                <div class="metric-label">{{ metric.label }}</div>
                <div class="metric-value">{{ metric.value }}</div>
                <div class="metric-subtext">{{ metric.subtext }}</div>
              </div>
            </el-card>
          </div>

          <div class="evolution-layout">
            <el-card class="glass-card">
              <div class="card-title-row">
                <span>进化摘要</span>
                <span class="card-meta">实时生成</span>
              </div>
              <pre class="evolution-summary">{{ evolutionSummary }}</pre>
            </el-card>

            <el-card class="glass-card">
              <div class="card-title-row">
                <span>最近学习记录</span>
                <span class="card-meta">{{ evolutionStats.recent_learnings.length }} 条</span>
              </div>
              <el-timeline v-if="evolutionStats.recent_learnings.length">
                <el-timeline-item
                  v-for="(item, i) in evolutionStats.recent_learnings"
                  :key="i"
                  :timestamp="formatDateTime(item.time)"
                  placement="top"
                >
                  <div class="timeline-card">
                    <div class="timeline-title">{{ item.agent }}</div>
                    <div class="timeline-desc">{{ item.task }}</div>
                    <div class="timeline-knowledge">{{ item.knowledge }}</div>
                    <div v-if="item.skill" class="timeline-skill">技能：{{ item.skill }}</div>
                    <div class="knowledge-tags">
                      <el-tag v-for="tag in (item.tags || [])" :key="tag" size="small" effect="dark">{{ tag }}</el-tag>
                    </div>
                  </div>
                </el-timeline-item>
              </el-timeline>
              <el-empty v-else description="暂无进化学习记录"></el-empty>
            </el-card>
          </div>
        </section>
      </el-main>
    </el-container>
  </el-container>

  <el-dialog
    v-model="agentChatVisible"
    :title="'与 ' + (chatAgent?.name || '') + ' 对话'"
    width="760px"
    destroy-on-close
  >
    <div class="agent-dialog-header" v-if="chatAgent">
      <div>
        <div class="agent-name">{{ chatAgent.name }}</div>
        <div class="agent-role">{{ chatAgent.role }}</div>
      </div>
      <div class="agent-tags">
        <el-tag size="small" effect="dark">{{ chatAgent.model || 'deepseek-v4-pro' }}</el-tag>
        <el-tag v-if="chatAgent.reasoning" size="small" effect="dark" color="#7c3aed">思考模式</el-tag>
      </div>
    </div>
    <div class="agent-chat-area">
      <div class="chat-messages" ref="agentChatMsgs">
        <div v-for="(m, i) in agentChatHistory" :key="i" class="chat-msg" :class="m.role">
          <div class="chat-bubble" v-html="formatContent(m.content)"></div>
        </div>
        <div v-if="agentChatLoading" class="chat-msg assistant">
          <div class="chat-bubble typing">智能体思考中…</div>
        </div>
      </div>
    </div>
    <template #footer>
      <el-input
        v-model="agentChatInput"
        placeholder="输入消息..."
        @keyup.enter="sendAgentChat"
        :disabled="agentChatLoading"
        clearable
      >
        <template #append>
          <el-button @click="sendAgentChat" :disabled="agentChatLoading" :icon="Promotion">发送</el-button>
        </template>
      </el-input>
    </template>
  </el-dialog>

  <el-dialog v-model="showNewAgentDialog" title="新增智能体配置建议" width="620px">
    <div class="new-agent-note">
      当前后端暂无新增智能体 API。这里生成一份可复制到 `agents_config/*.yaml` 的配置草案，方便后续手动接入。
    </div>
    <el-form :model="newAgentForm" label-position="top">
      <el-form-item label="名称">
        <el-input v-model="newAgentForm.name" placeholder="例如：Researcher" />
      </el-form-item>
      <el-form-item label="角色">
        <el-input v-model="newAgentForm.role" placeholder="例如：资料检索专家" />
      </el-form-item>
      <el-form-item label="描述">
        <el-input v-model="newAgentForm.description" type="textarea" :rows="3" placeholder="一句话描述智能体职责" />
      </el-form-item>
    </el-form>
    <div class="yaml-preview">{{ generatedAgentYaml }}</div>
    <template #footer>
      <el-button @click="showNewAgentDialog = false">关闭</el-button>
      <el-button type="primary" @click="copyGeneratedYaml">复制 YAML</el-button>
    </template>
  </el-dialog>

  <el-dialog v-model="addKbVisible" title="添加知识" width="520px">
    <el-form :model="addKbForm" label-position="top">
      <el-form-item label="内容">
        <el-input v-model="addKbForm.content" type="textarea" :rows="4" placeholder="输入知识内容..." />
      </el-form-item>
      <el-form-item label="标签（逗号分隔）">
        <el-input v-model="addKbForm.tagsStr" placeholder="例如：hermes, orchestration" />
      </el-form-item>
      <el-form-item label="来源">
        <el-input v-model="addKbForm.source" placeholder="例如：manual / evolution:Hermes" />
      </el-form-item>
    </el-form>
    <template #footer>
      <el-button @click="addKbVisible = false">取消</el-button>
      <el-button type="primary" @click="addKnowledge" :loading="kbAdding">添加知识</el-button>
    </template>
  </el-dialog>
</div>

<script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
<script src="https://unpkg.com/element-plus"></script>
<script src="https://unpkg.com/@element-plus/icons-vue"></script>
<script src="/static/app.js"></script>
</body>
</html>
