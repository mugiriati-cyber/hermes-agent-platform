/* =========================================
   Hermes 智能体管理平台 v3.0
   深紫玻璃态主题 — 极光渐变 + 星域粒子 + 毛玻璃
   ========================================= */

:root {
  --bg-deep: #080412;
  --bg-surface: rgba(15, 8, 30, 0.45);
  --bg-glass: rgba(22, 12, 44, 0.55);
  --bg-glass-hover: rgba(30, 16, 56, 0.65);
  --bg-glass-elevated: rgba(35, 20, 62, 0.72);
  --border-glass: rgba(168, 85, 247, 0.14);
  --border-glass-active: rgba(168, 85, 247, 0.35);
  --accent: #a855f7;
  --accent-secondary: #7c3aed;
  --accent-glow: rgba(168, 85, 247, 0.25);
  --accent-strong: rgba(168, 85, 247, 0.50);
  --accent-subtle: rgba(168, 85, 247, 0.08);
  --text-primary: #e2e0f0;
  --text-secondary: #9a90b8;
  --text-muted: #6b6088;
  --success: #22c55e;
  --success-glow: rgba(34, 197, 94, 0.18);
  --warning: #f59e0b;
  --warning-glow: rgba(245, 158, 11, 0.18);
  --info: #818cf8;
  --gradient-aurora-1: linear-gradient(135deg, #7c3aed 0%, #a855f7 35%, #6366f1 65%, #1e1b4b 100%);
  --gradient-aurora-2: linear-gradient(215deg, #4c1d95 0%, #7c3aed 45%, #312e81 100%);
  --gradient-accent: linear-gradient(135deg, #a855f7, #7c3aed);
  --gradient-text: linear-gradient(135deg, #c4b5fd, #a78bfa, #818cf8);
  --radius-sm: 8px;
  --radius-md: 14px;
  --radius-lg: 18px;
  --shadow-glass: 0 8px 32px rgba(0, 0, 0, 0.4);
  --shadow-glow: 0 0 40px rgba(168, 85, 247, 0.12);
  --shadow-card-hover: 0 12px 40px rgba(124, 58, 237, 0.18);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html { background: var(--bg-deep); height: 100%; }

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: var(--text-primary);
  height: 100vh;
  overflow: hidden;
  position: relative;
  background: var(--bg-deep);
}

/* ============ 极光背景层 ============ */

body::before {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 0;
  background:
    radial-gradient(ellipse 80% 50% at 20% 10%, rgba(124, 58, 237, 0.12) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 80% 20%, rgba(99, 102, 241, 0.10) 0%, transparent 55%),
    radial-gradient(ellipse 70% 60% at 50% 80%, rgba(168, 85, 247, 0.08) 0%, transparent 60%),
    radial-gradient(ellipse 50% 30% at 10% 70%, rgba(76, 29, 149, 0.10) 0%, transparent 50%);
  animation: aurora-drift 18s ease-in-out infinite;
}

@keyframes aurora-drift {
  0%, 100% {
    background:
      radial-gradient(ellipse 80% 50% at 20% 10%, rgba(124, 58, 237, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 20%, rgba(99, 102, 241, 0.10) 0%, transparent 55%),
      radial-gradient(ellipse 70% 60% at 50% 80%, rgba(168, 85, 247, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse 50% 30% at 10% 70%, rgba(76, 29, 149, 0.10) 0%, transparent 50%);
  }
  33% {
    background:
      radial-gradient(ellipse 80% 50% at 70% 15%, rgba(168, 85, 247, 0.14) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 25% 30%, rgba(124, 58, 237, 0.08) 0%, transparent 55%),
      radial-gradient(ellipse 70% 60% at 40% 75%, rgba(99, 102, 241, 0.10) 0%, transparent 60%),
      radial-gradient(ellipse 50% 30% at 80% 65%, rgba(76, 29, 149, 0.09) 0%, transparent 50%);
  }
  66% {
    background:
      radial-gradient(ellipse 80% 50% at 40% 8%, rgba(99, 102, 241, 0.10) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 70% 25%, rgba(168, 85, 247, 0.12) 0%, transparent 55%),
      radial-gradient(ellipse 70% 60% at 55% 85%, rgba(124, 58, 237, 0.07) 0%, transparent 60%),
      radial-gradient(ellipse 50% 30% at 15% 60%, rgba(76, 29, 149, 0.12) 0%, transparent 50%);
  }
}

/* ============ 星域粒子层 ============ */

body::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 0;
  background-image:
    radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,0.35), transparent),
    radial-gradient(1px 1px at 23% 8%, rgba(255,255,255,0.25), transparent),
    radial-gradient(1.5px 1.5px at 35% 22%, rgba(255,255,255,0.30), transparent),
    radial-gradient(1px 1px at 48% 5%, rgba(255,255,255,0.20), transparent),
    radial-gradient(1px 1px at 55% 18%, rgba(255,255,255,0.28), transparent),
    radial-gradient(1px 1px at 67% 10%, rgba(255,255,255,0.18), transparent),
    radial-gradient(1px 1px at 72% 32%, rgba(255,255,255,0.22), transparent),
    radial-gradient(1px 1px at 82% 14%, rgba(255,255,255,0.30), transparent),
    radial-gradient(1.5px 1.5px at 88% 28%, rgba(255,255,255,0.15), transparent),
    radial-gradient(1px 1px at 15% 65%, rgba(255,255,255,0.12), transparent),
    radial-gradient(1px 1px at 28% 72%, rgba(255,255,255,0.18), transparent),
    radial-gradient(1px 1px at 40% 58%, rgba(255,255,255,0.22), transparent),
    radial-gradient(1.5px 1.5px at 58% 75%, rgba(255,255,255,0.14), transparent),
    radial-gradient(1px 1px at 65% 85%, rgba(255,255,255,0.20), transparent),
    radial-gradient(1px 1px at 78% 62%, rgba(255,255,255,0.16), transparent),
    radial-gradient(1px 1px at 85% 78%, rgba(255,255,255,0.25), transparent),
    radial-gradient(1.5px 1.5px at 5% 85%, rgba(255,255,255,0.13), transparent),
    radial-gradient(1px 1px at 92% 55%, rgba(255,255,255,0.19), transparent),
    radial-gradient(1px 1px at 45% 90%, rgba(255,255,255,0.22), transparent);
  animation: stars-twinkle 6s ease-in-out infinite alternate;
}

@keyframes stars-twinkle {
  0% { opacity: 0.5; }
  100% { opacity: 1.0; }
}

/* ============ 布局 ============ */

.app-container {
  height: 100vh;
  background: transparent;
  position: relative;
  z-index: 1;
}

.app-aside {
  background: var(--bg-glass) !important;
  border-right: 1px solid var(--border-glass) !important;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  backdrop-filter: blur(24px) saturate(1.4);
  -webkit-backdrop-filter: blur(24px) saturate(1.4);
  position: relative;
}

.app-aside::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(168,85,247,0.04) 0%, transparent 30%, rgba(124,58,237,0.03) 100%);
  pointer-events: none;
}

/* LOGO */
.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 28px 20px 22px;
  font-size: 20px;
  font-weight: 700;
  background: var(--gradient-text);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 0.5px;
  position: relative;
}

.logo::after {
  content: '';
  position: absolute;
  bottom: 8px;
  left: 20px;
  right: 20px;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(168,85,247,0.25), transparent);
}

.logo .el-icon {
  -webkit-text-fill-color: #a78bfa;
  filter: drop-shadow(0 0 8px rgba(168,85,247,0.4));
}

.logo small {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 400;
  -webkit-text-fill-color: var(--text-muted);
}

.sidebar-footer {
  padding: 16px 20px;
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  border-top: 1px solid var(--border-glass);
  background: rgba(15,8,30,0.3);
}

/* ============ 菜单 ============ */

.side-menu {
  border-right: none !important;
  flex: 1;
  padding: 8px 0;
  background: transparent !important;
}

.side-menu .el-menu-item {
  font-size: 14px;
  margin: 3px 12px;
  border-radius: var(--radius-sm);
  height: 44px;
  line-height: 44px;
  transition: all 0.25s ease;
  position: relative;
  color: #9a90b8 !important;
}

.side-menu .el-menu-item:hover {
  background: rgba(168,85,247,0.08) !important;
  color: #c4b5fd !important;
}

.side-menu .el-menu-item.is-active {
  background: rgba(168,85,247,0.12) !important;
  color: #c4b5fd !important;
}

.side-menu .el-menu-item.is-active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 8px;
  bottom: 8px;
  width: 3px;
  background: var(--accent);
  border-radius: 0 2px 2px 0;
  box-shadow: 0 0 10px var(--accent), 0 0 20px rgba(168,85,247,0.4);
}

/* ============ 主区域 ============ */

.app-main {
  padding: 32px 36px;
  overflow-y: auto;
  height: 100vh;
  background: transparent;
  position: relative;
  z-index: 1;
}

.page { max-width: 1240px; }

.page-title {
  font-size: 24px;
  color: var(--text-primary);
  margin-bottom: 24px;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 10px;
}

.page-desc {
  color: var(--text-secondary);
  font-size: 13px;
  margin-bottom: 22px;
  margin-top: -18px;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mt-20 { margin-top: 20px; }
.mr-4 { margin-right: 4px; }

/* ============ 统计卡片 ============ */

.stat-card {
  background: var(--bg-glass) !important;
  border: 1px solid var(--border-glass) !important;
  border-radius: var(--radius-md) !important;
  transition: all 0.35s ease !important;
  overflow: hidden;
  position: relative;
  backdrop-filter: blur(16px) saturate(1.3);
  -webkit-backdrop-filter: blur(16px) saturate(1.3);
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--gradient-accent);
  opacity: 0;
  transition: opacity 0.35s ease;
}

.stat-card::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, rgba(168,85,247,0.04) 0%, transparent 50%, rgba(124,58,237,0.02) 100%);
  pointer-events: none;
}

.stat-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-card-hover), var(--shadow-glow) !important;
  border-color: var(--border-glass-active) !important;
}

.stat-card:hover::before { opacity: 1; }

.stat-card .el-card__body {
  text-align: center;
  padding: 32px 24px;
}

.stat-card .el-statistic__head {
  color: var(--text-secondary);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.3px;
}

.stat-card .el-statistic__content {
  background: var(--gradient-text);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-size: 38px;
  font-weight: 800;
}

/* ============ 智能体卡片 ============ */

.agent-card {
  cursor: pointer;
  transition: all 0.35s ease;
  margin-bottom: 16px;
  background: var(--bg-glass) !important;
  border: 1px solid var(--border-glass) !important;
  border-radius: var(--radius-md) !important;
  overflow: hidden;
  backdrop-filter: blur(16px) saturate(1.3);
  -webkit-backdrop-filter: blur(16px) saturate(1.3);
}

.agent-card::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, rgba(168,85,247,0.03) 0%, transparent 60%);
  pointer-events: none;
}

.agent-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-card-hover) !important;
  border-color: var(--border-glass-active) !important;
}

.agent-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.agent-name {
  font-weight: 700;
  background: var(--gradient-text);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-size: 16px;
}

.agent-role {
  color: var(--text-secondary);
  font-size: 13px;
  margin-bottom: 6px;
}

.agent-desc {
  color: var(--text-muted);
  font-size: 12px;
  margin-bottom: 10px;
  line-height: 1.5;
}

.agent-model {
  color: rgba(255,255,255,0.15);
  font-size: 11px;
  font-family: 'SF Mono', 'Fira Code', monospace;
}

/* ============ 单智能体对话 ============ */

.agent-chat-area {
  background: var(--bg-glass);
  border-radius: var(--radius-md);
  padding: 14px;
  height: 400px;
  overflow: hidden;
  border: 1px solid var(--border-glass);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.chat-messages { height: 100%; overflow-y: auto; padding-right: 4px; }
.chat-msg { margin-bottom: 14px; }

.chat-msg.user .chat-bubble {
  background: var(--gradient-accent);
  color: #fff;
  margin-left: auto;
  max-width: 70%;
  border-radius: 14px 14px 6px 14px;
  box-shadow: 0 4px 18px rgba(168,85,247,0.25);
}

.chat-msg.assistant .chat-bubble {
  background: var(--bg-glass-elevated);
  border: 1px solid var(--border-glass);
  max-width: 85%;
  border-radius: 14px 14px 14px 6px;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.chat-bubble {
  padding: 12px 16px;
  font-size: 14px;
  line-height: 1.6;
  display: inline-block;
  word-break: break-word;
}

.chat-bubble.typing {
  color: var(--text-muted);
  font-style: italic;
}

/* ============ 知识库 ============ */

.kb-search-bar { display: flex; gap: 10px; }
.kb-footer { margin-top: 12px; color: var(--text-muted); font-size: 12px; }

.kb-result-item {
  padding: 10px 14px;
  background: var(--bg-glass);
  border-radius: var(--radius-sm);
  margin-bottom: 8px;
  font-size: 13px;
  line-height: 1.6;
  color: var(--text-secondary);
  border: 1px solid var(--border-glass);
  transition: all 0.25s ease;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.kb-result-item:hover {
  background: var(--bg-glass-hover);
  border-color: var(--border-glass-active);
}

/* ============ 集群对话 ============ */

.cluster-chat-card {
  margin-bottom: 16px;
  background: var(--bg-glass) !important;
  border: 1px solid var(--border-glass) !important;
  border-radius: var(--radius-md) !important;
  backdrop-filter: blur(16px) saturate(1.3);
  -webkit-backdrop-filter: blur(16px) saturate(1.3);
}

.cluster-chat-card .el-card__body { padding: 18px; }

.cluster-messages {
  min-height: 400px;
  max-height: 55vh;
  overflow-y: auto;
  padding-right: 4px;
}

.empty-chat {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 400px;
}

.cluster-msg { margin-bottom: 20px; }
.cluster-msg.user { display: flex; justify-content: flex-end; }

.cluster-bubble {
  padding: 14px 18px;
  border-radius: var(--radius-md);
  font-size: 14px;
  line-height: 1.7;
  max-width: 80%;
  word-break: break-word;
  display: inline-block;
}

.user-bubble {
  background: var(--gradient-accent);
  color: #fff;
  border-radius: 14px 14px 6px 14px;
  box-shadow: 0 4px 18px rgba(168,85,247,0.25);
}

.assistant-bubble {
  background: var(--bg-glass-elevated);
  border: 1px solid var(--border-glass);
  border-radius: 14px 14px 14px 6px;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.assistant-bubble.typing { color: var(--text-muted); font-style: italic; }

.orchestration-header, .knowledge-header, .agent-header { margin-bottom: 8px; }
.cluster-content { white-space: pre-wrap; }

.cluster-input {
  display: flex;
  gap: 10px;
  align-items: flex-end;
}

.cluster-input .el-textarea { flex: 1; }

/* ============ 进化系统 ============ */

.evolution-summary {
  color: var(--text-secondary);
  font-size: 13px;
  line-height: 1.7;
  white-space: pre-wrap;
  font-family: inherit;
  background: transparent;
  border: none;
  padding: 0;
}

/* ============ 思考过程 ============ */

.thinking-block { margin-top: 8px; cursor: pointer; }

.thinking-block summary {
  color: var(--accent);
  font-size: 12px;
  user-select: none;
  opacity: 0.75;
  transition: opacity 0.2s ease;
}

.thinking-block summary:hover { opacity: 1; }

.answer-block { margin-bottom: 4px; }

/* ============ Element Plus 暗色玻璃态覆盖 ============ */

.el-card {
  background: var(--bg-glass) !important;
  border-color: var(--border-glass) !important;
  color: var(--text-primary) !important;
  border-radius: var(--radius-md) !important;
  transition: all 0.35s ease;
  backdrop-filter: blur(16px) saturate(1.3);
  -webkit-backdrop-filter: blur(16px) saturate(1.3);
}

.el-card__header {
  border-bottom-color: var(--border-glass) !important;
  color: var(--text-primary) !important;
  font-weight: 600;
}

.el-card__body { color: var(--text-primary) !important; }

.el-menu {
  background: transparent !important;
}

.el-table {
  --el-table-bg-color: var(--bg-glass);
  --el-table-tr-bg-color: transparent;
  --el-table-header-bg-color: rgba(30,16,56,0.4);
  --el-table-row-hover-bg-color: rgba(168,85,247,0.06);
  --el-table-border-color: var(--border-glass);
  --el-table-text-color: var(--text-primary);
  --el-table-header-text-color: var(--text-secondary);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.el-input__inner, .el-textarea__inner {
  background: var(--bg-glass) !important;
  border-color: var(--border-glass) !important;
  color: var(--text-primary) !important;
  border-radius: var(--radius-sm) !important;
  transition: all 0.25s ease;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.el-input__inner:focus, .el-textarea__inner:focus {
  border-color: var(--accent) !important;
  box-shadow: 0 0 0 3px var(--accent-subtle), 0 0 12px rgba(168,85,247,0.12) !important;
}

.el-input__inner::placeholder, .el-textarea__inner::placeholder {
  color: var(--text-muted) !important;
}

.el-input-group__append {
  background: var(--gradient-accent) !important;
  border-color: transparent !important;
  color: #fff !important;
  box-shadow: 0 2px 8px rgba(168,85,247,0.3);
}

.el-input-group__prepend {
  background: var(--bg-glass) !important;
  border-color: var(--border-glass) !important;
  color: var(--text-secondary) !important;
}

.el-dialog {
  background: var(--bg-glass) !important;
  border: 1px solid var(--border-glass) !important;
  border-radius: var(--radius-lg) !important;
  box-shadow: 0 24px 64px rgba(0,0,0,0.5), var(--shadow-glow) !important;
  backdrop-filter: blur(28px) saturate(1.5);
  -webkit-backdrop-filter: blur(28px) saturate(1.5);
}

.el-dialog__header {
  border-bottom: 1px solid var(--border-glass) !important;
  padding: 22px 26px !important;
}

.el-dialog__title { color: var(--text-primary) !important; font-weight: 700; }

.el-dialog__body {
  color: var(--text-primary) !important;
  padding: 22px 26px !important;
}

.el-dialog__headerbtn .el-dialog__close {
  color: var(--text-secondary) !important;
}

.el-dialog__headerbtn .el-dialog__close:hover {
  color: var(--accent) !important;
}

.el-tag {
  border-color: transparent !important;
  border-radius: 6px !important;
  font-weight: 500;
}

.el-statistic__head { color: var(--text-secondary) !important; }
.el-statistic__content { color: var(--accent) !important; }

.el-descriptions__label { color: var(--text-secondary) !important; }
.el-descriptions__content { color: var(--text-primary) !important; }
.el-descriptions { --el-descriptions-table-bg: transparent; }
.el-descriptions__body { background: transparent !important; }
.el-descriptions__cell { background: transparent !important; }

.el-empty__description { color: var(--text-muted) !important; }
.el-empty { --el-empty-fill-color-0: rgba(168,85,247,0.06); }

.el-button--primary {
  --el-button-bg-color: #7c3aed;
  --el-button-border-color: #7c3aed;
  --el-button-hover-bg-color: #6d28d9;
  --el-button-hover-border-color: #6d28d9;
  --el-button-active-bg-color: #5b21b6;
  font-weight: 500;
  border-radius: var(--radius-sm);
  box-shadow: 0 2px 12px rgba(124,58,237,0.3);
  transition: all 0.25s ease;
}

.el-button--primary:hover {
  box-shadow: 0 4px 20px rgba(124,58,237,0.45);
  transform: translateY(-1px);
}

.el-button--default {
  --el-button-bg-color: var(--bg-glass);
  --el-button-border-color: var(--border-glass);
  --el-button-hover-bg-color: var(--bg-glass-hover);
  --el-button-hover-border-color: var(--border-glass-active);
  --el-button-active-bg-color: var(--bg-glass);
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.el-button--default:hover {
  color: var(--text-primary);
}

.el-timeline-item__node {
  background: var(--accent) !important;
  box-shadow: 0 0 8px rgba(168,85,247,0.3);
}

.el-timeline-item__tail { border-color: var(--border-glass) !important; }
.el-timeline-item__timestamp { color: var(--text-muted) !important; }

.el-alert {
  border-radius: var(--radius-sm) !important;
  background: var(--bg-glass) !important;
  border-color: var(--border-glass) !important;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.el-select-dropdown, .el-dropdown-menu, .el-picker-panel {
  background: var(--bg-glass) !important;
  border-color: var(--border-glass) !important;
  backdrop-filter: blur(24px) saturate(1.5);
  -webkit-backdrop-filter: blur(24px) saturate(1.5);
  box-shadow: 0 16px 48px rgba(0,0,0,0.4) !important;
}

.el-select-dropdown__item, .el-dropdown-menu__item {
  color: var(--text-secondary) !important;
}

.el-select-dropdown__item:hover, .el-dropdown-menu__item:hover {
  background: rgba(168,85,247,0.08) !important;
  color: var(--text-primary) !important;
}

.el-select-dropdown__item.selected {
  color: var(--accent) !important;
  background: var(--accent-subtle) !important;
}

.el-form-item__label {
  color: var(--text-secondary) !important;
  font-weight: 500;
}

.el-loading-mask {
  background: rgba(8,4,18,0.6) !important;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}

.el-popper {
  background: var(--bg-glass) !important;
  border: 1px solid var(--border-glass) !important;
  backdrop-filter: blur(24px) saturate(1.5);
  -webkit-backdrop-filter: blur(24px) saturate(1.5);
  box-shadow: 0 16px 48px rgba(0,0,0,0.4) !important;
  color: var(--text-primary) !important;
}

.el-popper__arrow::before {
  background: var(--bg-glass) !important;
  border: 1px solid var(--border-glass) !important;
}

.el-overlay {
  background: rgba(8,4,18,0.55) !important;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

/* ============ 滚动条 ============ */

::-webkit-scrollbar { width: 6px; height: 6px; }

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(168,85,247,0.15);
  border-radius: 3px;
  transition: all 0.2s ease;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(168,85,247,0.3);
}

/* ============ Firefox scrollbar ============ */

* {
  scrollbar-width: thin;
  scrollbar-color: rgba(168,85,247,0.15) transparent;
}

/* ============ 动画 ============ */

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

.page { animation: fadeInUp 0.4s ease; }

@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 20px rgba(168,85,247,0.05); }
  50% { box-shadow: 0 0 35px rgba(168,85,247,0.18); }
}

.agent-card:hover {
  animation: pulse-glow 2.5s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-3px); }
}

/* ============ 选择高亮 ============ */

::selection {
  background: rgba(168,85,247,0.3);
  color: #fff;
}

/* ============ 焦点环 ============ */

:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
  border-radius: 2px;
}
